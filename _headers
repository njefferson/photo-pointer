# Cloudflare Pages headers (config file — must never be precached by sw.js).

/*
  X-Content-Type-Options: nosniff
  # NOT no-referrer: OpenStreetMap's tile servers reject requests with no Referer
  # ("Access blocked — Referer is required by tile usage policy"), blanking the
  # basemap. This sends only the origin cross-origin (no path leak, no HTTP downgrade).
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://tile.openstreetmap.org https://server.arcgisonline.com https://a.basemaps.cartocdn.com https://b.basemaps.cartocdn.com https://c.basemaps.cartocdn.com https://d.basemaps.cartocdn.com; connect-src 'self' https://api.open-meteo.com https://air-quality-api.open-meteo.com; base-uri 'none'; object-src 'none'; frame-ancestors 'none'

/sw.js
  Cache-Control: no-store
